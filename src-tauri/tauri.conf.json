{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Mjeku",
  "version": "0.5.4",
  "identifier": "com.mjeku.desktop",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix ../mjeku-ui run build && node scripts/prepare_ui_seed.mjs",
    "frontendDist": "../frontend-dist"
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "Mjeku",
        "width": 1100,
        "height": 720,
        "maximized": true,
        "resizable": true,
        "url": "mjeku://localhost/index.html"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "resources/ui-seed.zip",
      "resources/ui-seed-version.txt"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "iOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzQTAwMTY5N0ExRkIzN0MKUldSOHN4OTZhUUdnSStZMzZiZ09IY3NQSXNNUVZrbnBOZjdqNWFLbDgvNEZCTjNVSFpjNlhBQ0IK",
      "endpoints": [
        "https://mjeku-ui.vercel.app/desktop-update.json"
      ],
      "dialog": false
    }
  }
}
